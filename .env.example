# 複製此檔案為 .env.local，填入從 Firebase 控制台取得的值
# Firebase Console → 專案設定 → 您的應用程式 → firebaseConfig

VITE_FIREBASE_API_KEY=填入你的_apiKey
VITE_FIREBASE_AUTH_DOMAIN=填入你的_authDomain
VITE_FIREBASE_PROJECT_ID=填入你的_projectId
VITE_FIREBASE_STORAGE_BUCKET=填入你的_storageBucket
VITE_FIREBASE_MESSAGING_SENDER_ID=填入你的_messagingSenderId
VITE_FIREBASE_APP_ID=填入你的_appId
